{
  "name": "invoice-maker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run template:check && npm run typecheck && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "capability:check": "node scripts/check-capability-gates.mjs",
    "template:sync": "node scripts/sync-template.mjs",
    "template:check": "node scripts/sync-template.mjs --check",
    "capability:list": "node scripts/check-capability-gates.mjs --list",
    "test:run": "vitest run",
    "qa:verify": "node scripts/qa-verify.mjs",
    "qa:record-demos": "node scripts/record-demos.mjs",
    "qa:record-proof": "OUT_DIR=proof-recordings node scripts/record-demos.mjs",
    "check:trace": "node scripts/check-traceability.mjs",
    "check:coverage": "node scripts/check-coverage-ratchet.mjs",
    "check:eval": "node scripts/check-eval-ratchet.mjs",
    "check:trajectory": "node scripts/check-trajectory.mjs",
    "check:recordings": "node scripts/check-recordings.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "gate:status": "node scripts/gate-status.mjs",
    "correct": "node scripts/correct.mjs",
    "retro:digest": "node scripts/ledger-report.mjs",
    "check:acceptance": "node scripts/check-acceptance-methods.mjs --mode=existence",
    "check:acceptance:artifact": "node scripts/check-acceptance-methods.mjs --mode=artifact",
    "check:process": "node scripts/check-process-ratchet.mjs",
    "check:integrity": "node scripts/check-factory-integrity.mjs",
    "check:visual": "node scripts/check-visual-fidelity.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.5.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native": "npm:typescript@^7.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10",
    "yaml": "^2.8.0"
  }
}
